   <property name="styleSheet">
    <string notr="true">QTableWidget {
    background-color: #FFFFFF;
    alternate-background-color: #F8FAFC; /* Màu xám xanh cực nhạt cho dòng chẵn/lẻ */
    border: 1px solid #E5E7EB;
    border-radius: 8px;
    gridline-color: #E5E7EB; /* Lưới mờ */
    outline: none;
}

/* Thanh Tiêu đề (Header) */
QHeaderView::section {
    background-color: #EFF6FF; /* Nền xanh dương cực nhạt */
    color: #1E40AF; /* Chữ xanh đậm */
    font-weight: bold;
    border: none;
    border-bottom: 2px solid #BFDBFE; /* Đường kẻ dưới của Header */
    padding: 8px;
	font-size: 15px;
}

/* Các ô dữ liệu */
QTableWidget::item {
    padding: 5px;
	color: rgb(0, 0, 0);
}</string>
