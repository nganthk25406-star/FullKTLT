   <property name="styleSheet">
    <string notr="true">/* 1. Xóa viền ngoài cùng của bảng */
QTableWidget {
    border: none; 
    background-color: #F9FAFB; /* Nền hơi xám nhẹ cho sang */
}

/* 2. CHỈNH NỘI DUNG: Chữ màu Đen, bỏ viền từng ô */
QTableWidget::item {
    border: none;
    color: #000000; /* &lt;-- NỘI DUNG MÀU ĐEN */
    padding: 5px;
}

/* Ép màu cho Toàn bộ khung Header (để xóa cái mảng màu xám dư thừa) */
QHeaderView {
    background-color: #F9FAFB;
    border: none;
}

/* Ép màu cho Từng ô chữ Header */
QHeaderView::section {
    background-color: #F9FAFB;
    border: none;
    color: #3B82F6; 
    font-weight: bold;
    font-size: 12px;
}</string>
