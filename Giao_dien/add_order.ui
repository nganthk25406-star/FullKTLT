      <property name="styleSheet">
       <string notr="true">QComboBox {
    border: 1px solid #D1D5DB; /* Màu viền xám nhạt giống LineEdit */
    border-radius: 6px;        /* Bo góc nhẹ nhàng */
    padding: 4px 10px;         /* Khoảng cách chữ với viền */
    background-color: #F9FAFB;
    font-size: 13px;           /* Chỉnh size chữ cho dễ đọc */
    min-height: 30px;          /* Chiều cao khớp với các ô nhập liệu */
}

/* Tùy chỉnh cái nút mũi tên bên phải cho tinh tế */
QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: url(icon/chevron-down.png); /* Nếu m có icon mũi tên thì nhét vào đây */
    width: 12px;
    height: 12px;
}

/* Hiệu ứng khi click vào cho giống Figma */
QComboBox:focus {
    border: 2px solid #3B82F6; /* Viền xanh khi đang chọn */
}</string>
