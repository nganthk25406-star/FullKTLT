         <property name="styleSheet">
          <string notr="true">QListWidget {
    background-color: transparent;
    border: none;
    outline: none;
}
QListWidget::item {
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 12px;
    color: #4B5563;
    font-weight: bold;
}
QListWidget::item:hover { 
    background-color: #EBF5FF; /* Xanh dương cực nhạt */
}
QListWidget::item:selected {
    background-color: #007BFF; /* Xanh dương chủ đạo */
    color: white;
}</string>
